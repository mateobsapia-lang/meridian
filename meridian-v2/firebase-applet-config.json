rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function uid() { return request.auth.uid; }
    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(uid())) &&
        get(/databases/$(database)/documents/users/$(uid())).data.role == "admin";
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // ─── USERS ───────────────────────────────────────────────
    match /users/{userId} {
      allow get: if isSignedIn() && (uid() == userId || isAdmin());
      allow create: if isSignedIn() && uid() == userId &&
        incoming().keys().hasAll(['email', 'role']) &&
        incoming().role in ['buyer', 'seller'];
      // Users can update their own profile fields and switch between buyer/seller
      // but NEVER to admin — admin can only be set directly in Firestore console
      allow update: if isSignedIn() && uid() == userId &&
        incoming().diff(existing()).affectedKeys().hasOnly(['buyerProfile', 'displayName', 'role']) &&
        (
          !incoming().diff(existing()).affectedKeys().hasAny(['role']) ||
          (incoming().role in ['buyer', 'seller'] && existing().role in ['buyer', 'seller'])
        );
    }

    // ─── DEALS ───────────────────────────────────────────────
    match /deals/{dealId} {
      // Anyone can read published deals
      allow get: if existing().status == 'published' ||
        (isSignedIn() && existing().ownerId == uid()) ||
        isAdmin();

      // Use collection group queries filtered by status on client
      allow list: if isAdmin() ||
        (isSignedIn() && request.query.filters.size() > 0);

      allow create: if isSignedIn() &&
        incoming().ownerId == uid() &&
        incoming().status == 'under_review' &&
        incoming().nombreFantasia is string &&
        incoming().nombreFantasia.size() > 0 &&
        incoming().revenue is number &&
        incoming().ebitda is number &&
        incoming().askingPrice is number;

      allow update: if isAdmin() ||
        (isSignedIn() && existing().ownerId == uid() &&
         incoming().ownerId == uid() &&
         incoming().diff(existing()).affectedKeys().hasOnly([
           'nombreFantasia','industria','region','descripcion','updatedAt',
           'revenue','ebitda','crecimiento','deuda','askingPrice',
           'tipoSocietario','jurisdiccion','representante','telefono','email','highlights'
         ]));

      // Allow metric increments (viewCount, ndaRequests, etc.)
      allow update: if isSignedIn() &&
        incoming().diff(existing()).affectedKeys().hasOnly(['viewCount','ndaRequests','ndaSigned','dataRoomAccess','ioiCount','updatedAt']);

      allow delete: if isAdmin();
    }

    // ─── NDAs ────────────────────────────────────────────────
    match /ndas/{ndaId} {
      allow read: if isSignedIn() && (
        existing().buyerId == uid() ||
        isAdmin() ||
        // Seller can read NDAs on their deals
        get(/databases/$(database)/documents/deals/$(existing().dealId)).data.ownerId == uid()
      );
      allow list: if isSignedIn();
      allow create: if isSignedIn() &&
        incoming().buyerId == uid() &&
        incoming().status == 'pending';
      allow update: if isSignedIn() && (
        isAdmin() ||
        existing().buyerId == uid() && incoming().status == 'signed'
      );
    }

    // ─── AUDIT LOGS ──────────────────────────────────────────
    match /auditLogs/{logId} {
      allow create: if isSignedIn() && incoming().userId == uid();
      allow read: if isAdmin() ||
        (isSignedIn() && get(/databases/$(database)/documents/deals/$(existing().dealId)).data.ownerId == uid());
      allow list: if isAdmin() ||
        (isSignedIn() && request.query.filters.size() > 0);
    }

    // ─── NOTIFICATIONS ───────────────────────────────────────
    match /notifications/{notifId} {
      allow read, list: if isSignedIn() && existing().userId == uid();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && existing().userId == uid() &&
        incoming().diff(existing()).affectedKeys().hasOnly(['read']);
    }

    // ─── DOCUMENTS ───────────────────────────────────────────
    match /documents/{docId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        get(/databases/$(database)/documents/deals/$(existing().dealId)).data.ownerId == uid()
        // TODO: also allow buyers with signed NDA
      );
      allow list: if isSignedIn();
      allow create: if isSignedIn() &&
        get(/databases/$(database)/documents/deals/$(incoming().dealId)).data.ownerId == uid();
      allow delete: if isAdmin();
    }
  }
}
